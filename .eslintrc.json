{
	"root": true,
	"extends": [
		"wikimedia/client",
		"wikimedia/jquery",
		"wikimedia/mediawiki"
	],
	"globals": {
		"mediaWiki": false,
		"jQuery": false
	},
	"rules": {
		"no-unused-vars": "warn",
		"no-shadow": "warn",
		"no-underscore-dangle": "warn",
		"no-prototype-builtins": "warn",
		"no-jquery/no-global-selector": "warn",
		"no-jquery/no-fade": "warn",
		"no-jquery/no-extend": "warn",
		"es-x/no-object-assign": "warn",
		"no-mixed-spaces-and-tabs": "warn",
		"prefer-const": "warn",
		"implicit-arrow-linebreak": "warn",
		"no-jquery/no-done-fail": "warn"
	}
}
